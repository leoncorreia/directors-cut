{
  "name": "directors-cut",
  "version": "1.0.0",
  "description": "CineAgent — full-stack AI film director (Z.AI GLM-5.1 + Seedance + Butterbase)",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "npm run dev --prefix client",
    "dev:server": "cd server && ts-node-dev --respawn index.ts",
    "build": "npm run build --prefix client"
  },
  "keywords": [
    "react",
    "vite",
    "express",
    "glm",
    "seedance"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
