# Z.AI GLM — https://docs.z.ai/guides/llm/glm-5.1
VITE_ZAI_API_KEY=your_zai_key_here
VITE_ZAI_MODEL=glm-5.1
# VITE_ZAI_BASE_URL=https://api.z.ai/api/paas/v4
VITE_BUTTERBASE_APP_ID=app_your_app_id
VITE_BUTTERBASE_API_URL=https://api.butterbase.ai
VITE_BUTTERBASE_DEV_URL=
VITE_API_BASE=

# Seedance / BytePlus ModelArk — https://docs.byteplus.com/en/docs/ModelArk/1298459
# Use the data-plane base (…/api/v3). The proxy calls POST/GET …/contents/generations/tasks
SEEDANCE_API_KEY=your_ark_api_key_here
SEEDANCE_API_BASE=https://ark.ap-southeast.bytepluses.com/api/v3
SEEDANCE_MODEL=dreamina-seedance-2-0-260128
SEEDANCE_RESOLUTION=720p
SEEDANCE_GENERATE_AUDIO=true

CORS_ORIGINS=
